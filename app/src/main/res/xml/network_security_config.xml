<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 基础配置：信任系统和用户证书 -->
    <base-config>
        <trust-anchors>
            <certificates src="system" /> <!-- 系统证书 -->
            <certificates src="user" />   <!-- 用户安装的证书 -->
        </trust-anchors>
    </base-config>
</network-security-config>